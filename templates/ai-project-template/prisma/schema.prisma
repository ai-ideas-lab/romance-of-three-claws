// ============================================
// System Configuration
// ============================================

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  description String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  
  @@map("system_configs")
}
